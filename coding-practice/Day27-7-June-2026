# Ansible - Task

---
- name: Install Nginx and Enable the service
  hosts: all
  become: yes

  tasks:
    - name: install nginx
      package:
        name: nginx
        state: present

    - name: Enable & Start Nginx Service
      service:
        name: nginx
        state: started
        enabled: true

# Terraform - Task
provider "aws" {
    region = "ap-south-a"
}

resource "aws_instance" "PathnexEC2" {
    ami = "0abcd12340abcd"
    image_type = "cxi.4xlarge"

    tags = {
        Name = "Pathnex-student-ec2"
        Owner = "PathnexStudent"
    }
}

# Kubernetes - 3 Replica Deployment

---
apiVersion: apps/v1
kind: Deployment
metadata:
    name: nginx-deployment
spec:
    replicas: 3
    selector:
        matchLabels:
            app: nginx
        spec:
            containers:
                - name: nginx
                  image: nginx
                  ports: 
                    - containerPort: 80

