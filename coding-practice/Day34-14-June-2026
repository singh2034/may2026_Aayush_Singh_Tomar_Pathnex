# Terraform - Main.tf

provider "aws" {
    region = "us-east-1"
}

resource "aws_key_pair" "pathnex" {
    key_name = "pathnex-key"
    public_key = file("~/.ssh/id_rsa.pub")
}

resource "aws_security_group" "pathnex_sg" {
    name = "pathnex-sg"

    ingress {
        from_port = 22
        to_port = 22
        protocol = "tcp"
        cidr_blocks = ["0.0.0.0/0"]
    }

    ingress {
        from_port = 80
        to_port = 80
        protocol = 'tcp'
        cidr_blocks = ["0.0.0.0/0"]
    }

    egress {
        from_port = 0
        to_port = 0
        protocol = "-1"
        cidr_blocks = ["0.0.0.0/0"]
    }
}

resources "aws_instance" "pathnex" {
    ami = "ami-0acbd12340acbd"
    instance_type = "c5.xlarge"
    key_name = aws_key_pair.pathnex.key_name
    vpc_security_groups_ids = [aws_security_group.pathnex_sg.id]

    tags = {
        Name = "Pathnex-Training"
    }
}

resource "aws_volume_attachement" "ebs_attach" {
    device_name = "/dev/sdf"
    volume_id = aws_ebs_volume.pathnex_ebs.id
    instance_id = aws_instance.pathnex.id
}

# Variables.tf

variable "region" {
    default = "us-east-1"
}

# outputs.tf
output "instance_public_ip" {
    value = aws_instance.pathnex.public_ip
}

# Ansible - deploy files

---
- name: configure nginx
  hosts: web
  become: yes

  tasks:
    - name: Install nginx
      package:
        name: nginx
        state: present

    - name: Deploy HTML page
      copy:
        dest: /usr/share/nginx/html/index.html
        content: |
            <html>
            <body>
            <h1> welcome to pathnex </h1>
            </body>
            </html>

    - name: enable nginx
      service:
        name: nginx
        enabled: yes
        state: started

# Kubernetes

#pvc.yaml

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
    name: nginx-pvc
spec:
    accessModes:
        -  ReadWriteOnce
    
    resources:
        requests:
            storage: 1Gi

# Deployment.yaml

apiVersion: apps/v1
kind: Deployment
metadata:
    name: nginx-deployment

spec:
    replicas: 2

    selector:
        matchLabels:
            app: nginx
    
    template:
        metadata:
            labels:
                app: nginx

        spec:
            containers:
            - name: nginx
              image: nginx:latest

              ports:
              - containerPort: 80

              volumeMounts:
              - mountPath: /usr/share/nginx/html
                name: web-storage

            volumes:
            - name: web-storage
              persistentVolumeClaim:
                claimName: nginx-pvc

# Service.yaml
apiVersion: v1
kind: service
metadata:
    name: nginx-services

spec:
    type: NodePort

    selector:
        app: nginx
    
    ports:
    - port: 80
      targetPort: 80
      nodePort: 30080

