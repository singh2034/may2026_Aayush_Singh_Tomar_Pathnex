# Nginx Install - Ansible

---
- name: Install Nginx
  hosts: all
  become: yes

  tasks:
   - name: Install nginx on pathnex server
     yum:
        name: nginx
        state: present


# Terraform - launch ec2 instance

provider "aws" {
    region = "ap-south-1"
}

resource "aws_instance" "pathnex-ec2" {
    ami = "ami-0abcd1234abcd1234"
    instance_type = "t3.medium"

    tags = {
        Name = "pathnex-ec2"
    }
}

